__pycache__/
*.py[cod]

# The lichess OAuth token and downloaded game records stay out of git.
lichess/lichess.env
lichess/game_records/

# League artifacts: landmarks and pinned reports only. In pinned run
# dirs the negation keeps forced-selfmate PGNs (the rare citable
# trophies) while draw PGNs stay out; report.json is never ignored.
# dev-* exploration runs stay out WHOLESALE — trophies included,
# deliberately: git cannot re-include files under an ignored
# directory, so a dev trophy never appears in git status and becomes
# citable only by promotion (re-run its recorded config into a pinned
# dir; process-stable seeds reproduce it bit-for-bit).
games/league/dev-*/
games/league/*/*.pgn
!games/league/*/*selfmate-forced*.pgn
