# Copy this file to lichess/lichess.env and paste your real token there.
# lichess/lichess.env is gitignored — the token must never reach git.
#
# The token is the OAuth token of the (already upgraded) BOT account,
# created at https://lichess.org/account/oauth/token with the bot:play
# scope. lichess-bot reads it from this environment variable, which
# overrides the placeholder in config.yml.
LICHESS_BOT_TOKEN=paste_your_token_here

# Optional engine knobs (defaults shown; see lichess/homemade.py):
# LOSEBOT_PROFILE=vi
# LOSEBOT_MODEL=zach
# LOSEBOT_DEPTH=2
#
# Model-free generalist fallback (strips fine, cannot convert — the
# first live game showed why this is not the default):
# LOSEBOT_PROFILE=current
# LOSEBOT_MODEL=
